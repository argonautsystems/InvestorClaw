# InvestorClaw — environment configuration
# Copy this file to .env and fill in your values.
# All API keys are optional (free tiers available). The skill uses yfinance as
# a no-key fallback for market data.

# ── Portfolio paths ───────────────────────────────────────────────────────────
# Directory containing your portfolio CSV/Excel files.
# Defaults to the skill's portfolios/ subdirectory if not set.
INVESTOR_CLAW_PORTFOLIO_DIR=

# Directory where analysis JSON, CSV, and Excel reports are saved.
# Defaults to ~/portfolio_reports/
INVESTOR_CLAW_REPORTS_DIR=

# ── Market & financial data ───────────────────────────────────────────────────
DATA_PROVIDER=yfinance

# Finnhub: real-time quotes and analyst ratings — https://finnhub.io/register
FINNHUB_KEY=

# Alpha Vantage: supplemental price data — https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=

# FRED (St. Louis Fed): Treasury & TIPS benchmark yields — https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Massive: analyst recommendations, Benzinga news — https://massive.com/
MASSIVE_API_KEY=

# ── News ──────────────────────────────────────────────────────────────────────
# NewsAPI: news correlation for holdings — https://newsapi.org/register
NEWSAPI_KEY=

# ── Local LLM consultation (optional, requires CERBERUS GPU node) ─────────────
# Set INVESTORCLAW_CONSULTATION_ENABLED=false to offload heavy portfolio synthesis
# to a local or network LLM via Ollama. Without this, InvestorClaw uses keyword
# heuristics (fully functional, less nuanced).
#
# Tested models — others will likely work, these have been validated:
#   gemma4:26b       (recommended — best synthesis quality)
#   gemma4:e4b       (lighter 4-bit variant, good quality/speed tradeoff)
#   nemotron-3-nano  (suitable for lower-VRAM setups)
#   qwen2.5:14b      (solid alternative)
#
# Run: /portfolio setup   to auto-detect available models on your endpoint.
INVESTORCLAW_DEPLOYMENT_MODE=
INVESTORCLAW_CONSULTATION_ENABLED=true
INVESTORCLAW_CONSULTATION_ENDPOINT=http://localhost:11434
INVESTORCLAW_CONSULTATION_MODEL=gemma4-consult
INVESTORCLAW_STONKMODE_MODEL=gemma4-consult
INVESTORCLAW_CONSULTATION_HMAC_KEY=
# ESPP positions: symbol:account (comma-separated; semicolon for multiple accounts per symbol)
ESPP_HOLDINGS=

# Account display-name overrides: raw_account_id:friendly_name (comma-separated)
# Use this to label accounts that appear in the CSV without descriptive names.
ACCOUNT_LABELS=

# Discretionary/advisor-managed accounts (comma-separated account IDs or substrings)
# These are flagged in reports so concentration reflects advisor decisions, not self-directed.
# Note: use the post-label name when ACCOUNT_LABELS is also set for an account.
MANAGED_ACCOUNTS=

INVESTORCLAW_PRICE_PROVIDER=
INVESTORCLAW_FALLBACK_CHAIN=
# Always fetch live prices from provider even when CSV has broker-supplied prices.
# Set to false to use CSV prices as-is (broker snapshot fidelity mode).
INVESTOR_CLAW_REFRESH_PRICES=

# Cloud LLM stonkmode provider (set INVESTORCLAW_STONKMODE_PROVIDER=openai_compat to activate)
INVESTORCLAW_STONKMODE_ENDPOINT=
INVESTORCLAW_STONKMODE_API_KEY=
# Default: ollama (CERBERUS). Set to openai_compat to use Grok/Claude/GPT for narration.
INVESTORCLAW_STONKMODE_PROVIDER=
